# Copy this file to .env and fill in the values

# SQLite database file (no changes needed for local dev)
DATABASE_URL=file:./dev.db

# BetterAuth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your_secret_here
BETTER_AUTH_URL=http://localhost:3000

# NodeMailer — Gmail SMTP (optional for dev, only needed for email notifications)
NODEMAILER_EMAIL=your_gmail@gmail.com
NODEMAILER_PASSWORD=your_gmail_app_password

# UTD Microsoft SSO — leave blank until OIT provides credentials
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=
